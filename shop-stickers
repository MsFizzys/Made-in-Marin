      <!-- Update: href, src, alt, name, price, and color-dots if multi-color -->

      <a class="product-card" data-price="4" href="product-sticker-mountain.html">
        <div class="product-img">
          <img src="sticker-mountain.png" alt="Mountain Logo Sticker" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"/>
          <span class="product-img-placeholder" style="display:none;width:100%;height:100%;align-items:center;justify-content:center;">Sticker Photo</span>
          <span class="product-badge">New</span>
          <div class="product-overlay"><span class="view-btn">View</span></div>
