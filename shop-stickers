        <p class="product-price">$4.00</p>
        <!-- Color dots — show if sticker comes in multiple colors -->
        <div class="color-dots">
          <div class="color-dot" style="background:#1C1C1A;" title="Black"></div>
          <div class="color-dot" style="background:#FFFFFF;border:1px solid #ccc;" title="White"></div>
          <div class="color-dot" style="background:#3D6B4F;" title="Forest Green"></div>
        </div>
      </a>

      <a class="product-card" data-price="5" href="product-sticker-3.html">
        <div class="product-img">
          <img src="sticker-3.png" alt="Sticker 3" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"/>
          <span class="product-img-placeholder" style="display:none;width:100%;height:100%;align-items:center;justify-content:center;">Sticker Photo</span>
          <div class="product-overlay"><span class="view-btn">View</span></div>
        </div>
        <p class="product-name">Sticker Name</p>
        <p class="product-price">$5.00</p>
      </a>

      <a class="product-card" data-price="4" href="product-sticker-4.html">
        <div class="product-img">
          <img src="sticker-4.png" alt="Sticker 4" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"/>
          <span class="product-img-placeholder" style="display:none;width:100%;height:100%;align-items:center;justify-content:center;">Sticker Photo</span>
          <div class="product-overlay"><span class="view-btn">View</span></div>
        </div>
        <p class="product-name">Sticker Name</p>
        <p class="product-price">$4.00</p>
      </a>

      <a class="product-card" data-price="4" href="product-sticker-5.html">
        <div class="product-img">
          <img src="sticker-5.png" alt="Sticker 5" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"/>
          <span class="product-img-placeholder" style="display:none;width:100%;height:100%;align-items:center;justify-content:center;">Sticker Photo</span>
          <div class="product-overlay"><span class="view-btn">View</span></div>
        </div>
        <p class="product-name">Sticker Name</p>
        <p class="product-price">$4.00</p>
      </a>

      <a class="product-card" data-price="4" href="product-sticker-6.html">
        <div class="product-img">
          <img src="sticker-6.png" alt="Sticker 6" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"/>
          <span class="product-img-placeholder" style="display:none;width:100%;height:100%;align-items:center;justify-content:center;">Sticker Photo</span>
          <div class="product-overlay"><span class="view-btn">View</span></div>
        </div>
        <p class="product-name">Sticker Name</p>
        <p class="product-price">$4.00</p>
      </a>

      <!-- CONTINUE ADDING STICKER CARDS HERE UP TO 30 -->
      <!-- Copy any card block above, update href, src, name, price -->

    </div>
    <div class="empty-state" id="empty-state">No stickers found.</div>
  </div>
</main>

<footer>
  <a href="index.html" class="footer-logo"><img src="logo.png" alt="Made in Marin" style="height:32px;width:auto;filter:invert(1);" /></a>
  <p class="footer-copy">© 2025 Made in Marin®</p>
  <div class="footer-social">
    <a href="#" aria-label="Instagram"><svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg></a>
