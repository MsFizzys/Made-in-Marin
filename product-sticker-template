<script>
  // Carousel
  let current = 0;
  const track = document.getElementById('carousel-track');
  const slides = track.querySelectorAll('.carousel-slide');
  const total = slides.length;
  const dotsContainer = document.getElementById('carousel-dots');
  const thumbnails = document.querySelectorAll('.thumbnail');

  slides.forEach((_, i) => {
    const dot = document.createElement('div');
    dot.className = 'dot' + (i === 0 ? ' active' : '');
    dot.onclick = () => goToSlide(i);
    dotsContainer.appendChild(dot);
  });

  function goToSlide(index) {
    current = index;
    track.style.transform = `translateX(-${current * 100}%)`;
    document.querySelectorAll('.dot').forEach((d, i) => d.classList.toggle('active', i === current));
    thumbnails.forEach((t, i) => t.classList.toggle('active', i === current));
  }

  function moveSlide(dir) {
    current = (current + dir + total) % total;
    goToSlide(current);
  }

  track.addEventListener('touchstart', e => { window._startX = e.touches[0].clientX; });
  track.addEventListener('touchend', e => {
    const diff = window._startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) moveSlide(diff > 0 ? 1 : -1);
  });

  // Color
  function selectColor(swatch) {
    document.querySelectorAll('.swatch').forEach(s => s.classList.remove('selected'));
    swatch.classList.add('selected');
    document.getElementById('color-dropdown').value = swatch.dataset.color;
  }

  function selectColorFromDropdown(select) {
    document.querySelectorAll('.swatch').forEach(s => s.classList.toggle('selected', s.dataset.color === select.value));
  }

  // Quantity
  let qty = 1;
  function changeQty(dir) {
    qty = Math.max(1, qty + dir);
    document.getElementById('qty-display').textContent = qty;
  }

  // Add to cart
  function addToCart() {
    const colorDropdown = document.getElementById('color-dropdown');
    // Only check color if the color section exists on this page
    if (colorDropdown && !colorDropdown.value) {
      alert('Please select a color.'); return;
    }
    alert('Added to cart! (Square integration coming soon)');
  }
</script>
