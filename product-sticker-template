    <img src="sticker-mountain-2.png" alt="View 2" onerror="this.style.display='none';" />
  </div>
</div>

<!-- PRODUCT DETAILS -->
<div class="product-detail">
  <p class="product-category">Sticker</p>
  <!-- CHANGE: product name -->
  <h1 class="product-name">Mountain Logo Sticker</h1>
